{
  "name": "@meshtastic/core",
	"version": "2.6.6-1",
	"description": "Core functionalities for Meshtastic web applications.",
  "exports": {
		".": "./mod.ts"
	},
  "type": "module", 
  "main": "./dist/mod.js",       
  "module": "./dist/mod.js",     
  "types": "./dist/mod.d.ts",    
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "jsrInclude": ["mod.ts", "src/**/*.ts"],
  "jsrExclude": ["dist"],
  "license": "GPL-3.0-only",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepack": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist LICENSE",
    "build": "tsdown --config ../tsdown.config.ts",
    "publish:npm": "pnpm clean && pnpm build && pnpm publish --access public --no-git-checks",
    "prepare:jsr": "rm -rf dist && pnpm dlx pkg-to-jsr",
    "publish:jsr": "pnpm run prepack && pnpm prepare:jsr && deno publish --allow-dirty --no-check"
  },
  "dependencies": {
    "crc": "npm:crc@^4.3.2"
  }
}