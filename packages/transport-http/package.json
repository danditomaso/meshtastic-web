{
 "name": "@meshtastic/transport-http",
 "version": "0.2.3-2",
 "description": "A transport layer for Meshtastic applications using HTTP.",
 "type": "module", 
 "exports": {
    ".": {
      "import": "./dist/mod.js",
      "types": "./dist/mod.d.ts",
      "jsr": "./mod.ts"
    }
  },
  "main": "./dist/mod.js",       
  "module": "./dist/mod.js",     
  "types": "./dist/mod.d.ts",    
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "jsrInclude": ["mod.ts", "src/**/*.ts"],
  "jsrExclude": ["dist"],
  "license": "GPL-3.0-only",
  "scripts": {
   "preinstall": "npx only-allow pnpm",
    "prepack": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist LICENSE",
    "build": "tsdown --config ../tsdown.config.ts",

    "publish:npm": "pnpm clean && pnpm build && pnpm publish --access public --no-git-checks",
    "prepare:jsr": "rm -rf dist && pnpm dlx pkg-to-jsr",
    "publish:jsr": "pnpm run prepack && pnpm prepare:jsr && deno publish --allow-dirty --no-check"
  },
  "dependencies": {
     "@meshtastic/core": "^2.6.6-1"
  }
}
